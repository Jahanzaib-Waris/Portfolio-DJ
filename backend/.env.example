# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Required in production (e.g. https://your-api.onrender.com) so Django trusts
# admin/CSRF-protected POST requests coming from your deployed domain.
CSRF_TRUSTED_ORIGINS=

# CORS (comma-separated origins allowed to call the API)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Postgres (leave blank to fall back to local SQLite for development)
# Get these from Supabase project settings -> Database -> Connection pooling
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Supabase Storage (leave blank to fall back to local disk media for development)
# Get these from Supabase project settings -> Storage -> S3 connection details
SUPABASE_STORAGE_BUCKET_NAME=
SUPABASE_STORAGE_ENDPOINT_URL=
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_REGION=us-east-1
